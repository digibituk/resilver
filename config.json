{
  "server": {
    "port": 8080
  },
  "layout": {
    "maxWidgets": 8,
    "direction": "row",
    "widgets": [
      { "module": "clock" },
      { "module": "weather" },
      { "module": "news" }
    ]
  },
  "modules": {
    "clock": {
      "config": {
        "format": "24h",
        "showSeconds": false,
        "showDate": true
      }
    },
    "weather": {
      "config": {
        "latitude": 51.4778356052696,
        "longitude": 0.323272352543598,
        "units": "celsius",
        "location": "Grays",
        "refreshIntervalSeconds": 1800
      }
    },
    "news": {
      "config": {
        "feedUrls": [
          "https://feeds.bbci.co.uk/news/rss.xml",
          "https://feeds.skynews.com/feeds/rss/uk.xml",
          "https://www.theguardian.com/uk/rss"
        ],
        "maxItems": 20,
        "refreshIntervalSeconds": 300,
        "cycleIntervalSeconds": 10
      }
    }
  },
  "update": {
    "enabled": true,
    "intervalHours": 24
  }
}
